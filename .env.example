# MoodCapture — Explainable AI Assistant
# Copy this file to ".env" and fill in your OpenAI API key.
# The .env file is git-ignored and will not be committed.
#
# If this key is missing or invalid, the app still works:
# the explanation card will display a deterministic local
# explanation built from the actual prediction numbers.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
